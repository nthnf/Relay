# Local development against Envoy Gateway.
# If MetalLB is enabled, use the Envoy LoadBalancer IP, for example 172.19.255.200:8080.
# If you are port-forwarding Envoy, use 127.0.0.1:18080.
GRPC_TARGET=172.19.255.200:8080

# Envoy routes gRPC by HTTP/2 authority. Service-specific values are preferred.
BOOTSTRAP_GRPC_AUTHORITY=bootstrap.local
CHAT_GRPC_AUTHORITY=chat.local
FRIENDSHIP_GRPC_AUTHORITY=friendship.local
IDENTITY_GRPC_AUTHORITY=identity.local
REALTIME_GRPC_AUTHORITY=realtime.local
WORKSPACE_GRPC_AUTHORITY=workspace.local

# Browser/BFF auth input names. The BFF forwards access tokens to Envoy as authorization metadata.
AUTHORIZATION_HEADER_NAME=authorization
ACCESS_TOKEN_COOKIE_NAME=access_token
